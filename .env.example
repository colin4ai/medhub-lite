# OpenAI API Key (required for embeddings and GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# API authentication (required for an internet-accessible deployment)
API_AUTH_KEY=generate_a_long_random_value
DEFAULT_TENANT_ID=default
# For tenant-bound demo authentication; use Cognito/JWT claims in production.
# TENANT_API_KEYS_JSON={"tenant-a":"key-a","tenant-b":"key-b"}

# Configuration (optional, defaults are set in config.py)
# LLM_MODEL=gpt-4o-mini
# EMBEDDING_MODEL=text-embedding-3-small
# CHROMA_PERSIST_DIR=./data/chroma_db
# SIMILARITY_THRESHOLD=0.425
# ENABLE_ENTAILMENT_VERIFIER=false
# MAX_UPLOAD_BYTES=20971520
